---
import SectionHeading from "./SectionHeading.astro";
import Translatable from "./Translatable.astro";

interface Bilingue { es: string; en: string }
interface Props {
  yaSabes: Bilingue[];
  tocaPracticar: Bilingue[];
}
const { yaSabes, tocaPracticar } = Astro.props;
---
<section class="section-card">
  <SectionHeading eyebrow="Cierre" title="Where you are now" />
  <p class="mb-4 text-sm text-ink-500">A quick wrap-up: what you can do, and what's still loose. Tap <strong>EN</strong> on any line for the English.</p>

  <div class="grid gap-5 sm:grid-cols-2">
    <div class="rounded-2xl bg-cream-100 p-4">
      <p class="section-eyebrow">Lo que ya sabes</p>
      <ul class="mt-3 space-y-3">
        {yaSabes.map((item) => (
          <li class="flex gap-2">
            <span aria-hidden="true" class="mt-2 inline-block h-2 w-2 shrink-0 rounded-full bg-olive-500"></span>
            <div class="flex-1">
              <Translatable es={item.es} en={item.en} variant="default" />
            </div>
          </li>
        ))}
      </ul>
    </div>

    {tocaPracticar.length > 0 && (
      <div class="rounded-2xl bg-terracotta-50/70 p-4">
        <p class="section-eyebrow">Lo que toca practicar</p>
        <ul class="mt-3 space-y-3">
          {tocaPracticar.map((item) => (
            <li class="flex gap-2">
              <span aria-hidden="true" class="mt-2 inline-block h-2 w-2 shrink-0 rounded-full bg-terracotta-400"></span>
              <div class="flex-1">
                <Translatable es={item.es} en={item.en} variant="default" />
              </div>
            </li>
          ))}
        </ul>
      </div>
    )}
  </div>
</section>
