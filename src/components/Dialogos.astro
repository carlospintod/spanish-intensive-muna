---
import SectionHeading from "./SectionHeading.astro";
import SpeakButton from "./SpeakButton.astro";
import Translatable from "./Translatable.astro";

interface Linea { hablante: string; texto: string; gloss?: string; audio?: string }
interface Contexto { es: string; en?: string }
interface Dialogo { titulo: string; contexto?: Contexto; lineas: Linea[] }
interface Props { dialogos: Dialogo[] }
const { dialogos } = Astro.props;
---
<section class="section-card">
  <SectionHeading eyebrow="Diálogos" title="How it sounds in real life" />
  <p class="mb-5 text-sm text-ink-500">Tap the speaker on any line. Read along, then try saying it back.</p>

  <div class="space-y-7">
    {dialogos.map((d) => (
      <article>
        <h3 class="font-display text-xl font-semibold text-ink-900">{d.titulo}</h3>
        {d.contexto && (
          <div class="mt-1">
            <Translatable es={d.contexto.es} en={d.contexto.en} variant="ctx" />
          </div>
        )}
        <ol class="mt-3 space-y-2">
          {d.lineas.map((line) => (
            <li class="flex gap-3 rounded-xl bg-cream-100 px-4 py-3">
              <span class="shrink-0 font-semibold text-terracotta-600">{line.hablante}:</span>
              <div class="flex-1">
                <div class="flex items-start gap-2">
                  <span class="flex-1 text-ink-900">{line.texto}</span>
                  <SpeakButton text={line.texto} audio={line.audio} size="sm" label={`Play: ${line.texto}`} />
                </div>
                {line.gloss && (
                  <p class="mt-1 text-xs italic text-ink-500">{line.gloss}</p>
                )}
              </div>
            </li>
          ))}
        </ol>
      </article>
    ))}
  </div>
</section>
