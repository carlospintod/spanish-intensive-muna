---
import SectionHeading from "./SectionHeading.astro";

interface Linea { hablante: string; texto: string; gloss?: string }
interface Dialogo { titulo: string; contexto?: string; lineas: Linea[] }
interface Props { dialogos: Dialogo[] }
const { dialogos } = Astro.props;
---
<section class="section-card">
  <SectionHeading step={4} eyebrow="Diálogos" title="Cómo suena en la vida real" />

  <div class="space-y-7">
    {dialogos.map((d) => (
      <article>
        <h3 class="font-display text-xl font-semibold text-ink-900">{d.titulo}</h3>
        {d.contexto && <p class="mt-1 text-sm italic text-ink-500">{d.contexto}</p>}
        <ol class="mt-3 space-y-2">
          {d.lineas.map((line) => (
            <li class="flex gap-3 rounded-xl bg-cream-100 px-4 py-3">
              <span class="shrink-0 font-semibold text-terracotta-600">{line.hablante}:</span>
              <span class="text-ink-900">
                {line.texto}
                {line.gloss && (
                  <span class="mt-1 block text-xs italic text-ink-500">{line.gloss}</span>
                )}
              </span>
            </li>
          ))}
        </ol>
      </article>
    ))}
  </div>
</section>
