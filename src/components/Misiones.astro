---
import SectionHeading from "./SectionHeading.astro";
import Translatable from "./Translatable.astro";

interface Bilingue { es: string; en: string }
interface Props {
  unit: number;
  misiones: { real: Bilingue; casa: Bilingue; reto: Bilingue };
}
const { unit, misiones } = Astro.props;

const tiers = [
  { key: "real", label: "Misión real", subtitle: "Out in the world", item: misiones.real, tone: "bg-terracotta-50 border-terracotta-100" },
  { key: "casa", label: "Misión en casa", subtitle: "Low stakes, with Carlos", item: misiones.casa, tone: "bg-cream-100 border-cream-200" },
  { key: "reto", label: "Reto opcional", subtitle: "A small confidence dare", item: misiones.reto, tone: "bg-white border-cream-200" },
] as const;
---
<section class="section-card">
  <SectionHeading eyebrow="Misiones" title="Something to do this week" />
  <p class="mb-4 text-sm text-ink-500">
    Three versions. If one feels too big, drop to the next. No deadlines, no streaks. Tap <strong>EN</strong> on any mission to see the English.
  </p>

  <div class="grid gap-3 sm:grid-cols-3">
    {tiers.map((t) => (
      <div class={`rounded-2xl border p-4 ${t.tone}`}>
        <p class="section-eyebrow">{t.label}</p>
        <p class="mt-0.5 text-xs italic text-ink-500">{t.subtitle}</p>
        <div class="mt-2">
          <Translatable es={t.item.es} en={t.item.en} variant="default" />
        </div>
        <label class="mission-toggle mt-3 inline-flex items-center gap-2 text-sm text-ink-700">
          <input
            type="checkbox"
            class="mission-check h-4 w-4 rounded border-cream-200 text-terracotta-500 focus:ring-terracotta-400"
            data-mission-key={`unit-${unit}-mision-${t.key}`}
          />
          ¡Hecho! (done)
        </label>
      </div>
    ))}
  </div>
  <p class="mt-3 text-xs text-ink-500">Marks save only on this device.</p>
</section>

<script>
  function initMissions() {
    document.querySelectorAll<HTMLInputElement>(".mission-check").forEach((cb) => {
      if (cb.dataset.bound) return;
      cb.dataset.bound = "true";
      const key = cb.dataset.missionKey!;
      try {
        cb.checked = localStorage.getItem(key) === "1";
      } catch {}
      cb.addEventListener("change", () => {
        try {
          localStorage.setItem(key, cb.checked ? "1" : "0");
        } catch {}
      });
    });
  }
  initMissions();
  document.addEventListener("astro:page-load", initMissions);
</script>
