---
import SectionHeading from "./SectionHeading.astro";
import Translatable from "./Translatable.astro";

interface Props { objetivo: string; objetivoEn?: string }
const { objetivo, objetivoEn } = Astro.props;
---
<section class="section-card">
  <SectionHeading eyebrow="Objetivo" title="What you'll be able to do" />
  <Translatable es={objetivo} en={objetivoEn} variant="default" className="text-lg" />
</section>
