---
import SectionHeading from "./SectionHeading.astro";

interface VocabItem { termino: string; gloss: string; nota?: string }
interface Props { items: VocabItem[] }
const { items } = Astro.props;
---
<section class="section-card">
  <SectionHeading step={2} eyebrow="Vocabulario" title="Las palabras de esta unidad" />
  <p class="mb-5 text-sm text-ink-500">Toca cada tarjeta para ver el significado.</p>

  <ul class="grid grid-cols-1 gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {items.map((item) => (
      <li>
        <button
          type="button"
          class="flashcard group block h-full w-full text-left"
          aria-label={`Tarjeta: ${item.termino}`}
        >
          <div class="flashcard-inner">
            <div class="flashcard-face flashcard-front">
              <span class="font-display text-xl font-semibold text-ink-900">{item.termino}</span>
              <span class="mt-2 text-xs uppercase tracking-widest text-ink-500">tocar para ver</span>
            </div>
            <div class="flashcard-face flashcard-back">
              <span class="font-medium text-ink-900">{item.gloss}</span>
              {item.nota && (
                <span class="mt-2 text-sm italic text-ink-700">{item.nota}</span>
              )}
            </div>
          </div>
        </button>
      </li>
    ))}
  </ul>
</section>

<style>
  .flashcard {
    perspective: 1000px;
    min-height: 9rem;
  }
  .flashcard-inner {
    position: relative;
    width: 100%;
    height: 100%;
    min-height: 9rem;
    transition: transform 0.5s cubic-bezier(0.2, 0.8, 0.2, 1);
    transform-style: preserve-3d;
  }
  .flashcard[data-flipped="true"] .flashcard-inner {
    transform: rotateY(180deg);
  }
  .flashcard-face {
    position: absolute;
    inset: 0;
    backface-visibility: hidden;
    -webkit-backface-visibility: hidden;
    border-radius: 1rem;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    justify-content: center;
    box-shadow: 0 6px 24px -8px rgba(168, 80, 50, 0.18);
    ring: 1px solid;
  }
  .flashcard-front {
    background: #FFFBF4;
    border: 1px solid #FBEACB;
  }
  .flashcard-back {
    background: #FBEDE6;
    border: 1px solid #F5D2C0;
    transform: rotateY(180deg);
  }
  .flashcard:hover .flashcard-front { background: #FEF5E7; }
</style>

<script>
  function initFlashcards() {
    document.querySelectorAll<HTMLButtonElement>(".flashcard").forEach((card) => {
      if (card.dataset.bound) return;
      card.dataset.bound = "true";
      card.addEventListener("click", () => {
        const flipped = card.dataset.flipped === "true";
        card.dataset.flipped = flipped ? "false" : "true";
      });
    });
  }
  initFlashcards();
  document.addEventListener("astro:page-load", initFlashcards);
</script>
