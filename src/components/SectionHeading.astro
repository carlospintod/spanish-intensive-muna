---
interface Props {
  eyebrow: string;
  title: string;
  step?: number;
}
const { eyebrow, title, step } = Astro.props;
---
<header class="mb-4">
  <p class="section-eyebrow">{step !== undefined ? `${step}. ${eyebrow}` : eyebrow}</p>
  <h2 class="mt-1 text-2xl font-semibold text-ink-900 sm:text-3xl">{title}</h2>
</header>
