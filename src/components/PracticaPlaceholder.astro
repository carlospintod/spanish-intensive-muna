---
import SectionHeading from "./SectionHeading.astro";
interface Props { nivel: "A1" | "A2" }
const { nivel } = Astro.props;
---
<section class="section-card border-dashed">
  <SectionHeading eyebrow="Práctica" title="Practice chat (coming soon)" />
  <p class="text-ink-900 leading-relaxed">
    A Claude-powered chat will live here. Castilian Spanish only, level <span class="pill">{nivel}</span>,
    scoped to this unit's vocab and grammar. It corrects gently and only switches to English if you ask.
  </p>
  <p class="mt-3 text-sm text-ink-500">
    Ships in Phase 3, once the serverless proxy holds the API key.
  </p>
</section>
