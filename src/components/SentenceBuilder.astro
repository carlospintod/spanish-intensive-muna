---
import SectionHeading from "./SectionHeading.astro";

interface Item { objetivo: string; objetivoEn?: string }
interface Props { items: Item[] }
const { items } = Astro.props;

function tokenize(s: string): string[] {
  return s.trim().split(/\s+/);
}

function shuffle<T>(arr: T[]): T[] {
  const a = arr.slice();
  for (let i = a.length - 1; i > 0; i--) {
    const j = Math.floor(Math.random() * (i + 1));
    [a[i], a[j]] = [a[j], a[i]];
  }
  return a;
}

const built = items.map((it) => {
  const tokens = tokenize(it.objetivo);
  return {
    objetivo: it.objetivo,
    objetivoEn: it.objetivoEn,
    tokens,
    shuffled: shuffle(tokens.map((t, i) => ({ t, i }))),
  };
});
---
<section class="section-card">
  <SectionHeading eyebrow="Construye" title="Build the sentence (capstone)" />
  <p class="mb-5 text-sm text-ink-500">
    Tap the words in the right order. Tap a placed word to send it back. Tap <strong>EN</strong> if you need a hint about meaning.
  </p>

  <ol class="space-y-6">
    {built.map((b, idx) => (
      <li class="sb-item rounded-2xl border border-cream-200 bg-white p-4" data-target={b.objetivo} data-idx={idx}>
        <div class="sb-stage flex min-h-[3.25rem] flex-wrap items-center gap-2 rounded-xl bg-cream-100 px-3 py-3 text-ink-900"></div>

        {b.objetivoEn && (
          <div class="mt-2 flex items-start gap-2">
            <span class="flex-1 text-xs uppercase tracking-wider text-ink-500">target meaning</span>
            <button
              type="button"
              class="en-toggle sb-en-toggle"
              aria-expanded="false"
              aria-label="Show English target"
            >EN</button>
          </div>
        )}
        {b.objetivoEn && (
          <p class="sb-en mt-1 hidden text-sm italic text-ink-500">{b.objetivoEn}</p>
        )}

        <div class="sb-bank mt-3 flex flex-wrap gap-2">
          {b.shuffled.map((tok) => (
            <button
              type="button"
              class="sb-tile rounded-lg border border-cream-200 bg-cream-50 px-3 py-2 text-ink-900 hover:bg-cream-100"
              data-token={tok.t}
              data-orig-index={tok.i}
            >
              {tok.t}
            </button>
          ))}
        </div>

        <div class="mt-3 flex items-center justify-between">
          <p class="sb-feedback hidden text-sm font-medium"></p>
          <button
            type="button"
            class="sb-reset ml-auto rounded-lg border border-cream-200 px-3 py-1.5 text-sm text-ink-700 hover:bg-cream-100"
          >↻ Reset</button>
        </div>
      </li>
    ))}
  </ol>
</section>

<style>
  .sb-tile[data-used="1"] { visibility: hidden; }
  .sb-stage .sb-placed {
    cursor: pointer;
    background: #FBEDE6;
    border: 1px solid #F5D2C0;
    padding: 0.375rem 0.625rem;
    border-radius: 0.5rem;
  }
  .sb-stage[data-state="correct"] {
    background: #E6F0DC;
  }
  .sb-stage[data-state="correct"] .sb-placed {
    background: #DDE7C8;
    border-color: #7A8450;
    pointer-events: none;
  }
</style>

<script>
  function initSb() {
    document.querySelectorAll<HTMLElement>(".sb-item").forEach((item) => {
      if (item.dataset.bound) return;
      item.dataset.bound = "true";
      const target = item.dataset.target!;
      const stage = item.querySelector<HTMLElement>(".sb-stage")!;
      const bank = item.querySelector<HTMLElement>(".sb-bank")!;
      const feedback = item.querySelector<HTMLElement>(".sb-feedback")!;
      const reset = item.querySelector<HTMLButtonElement>(".sb-reset")!;
      const enToggle = item.querySelector<HTMLButtonElement>(".sb-en-toggle");
      const enText = item.querySelector<HTMLElement>(".sb-en");

      enToggle?.addEventListener("click", () => {
        if (!enText) return;
        const willShow = enText.classList.contains("hidden");
        enText.classList.toggle("hidden");
        enToggle.setAttribute("aria-expanded", String(willShow));
      });

      function check() {
        const placed = Array.from(stage.querySelectorAll<HTMLElement>(".sb-placed"))
          .map((p) => p.dataset.token).join(" ");
        if (placed === target) {
          stage.dataset.state = "correct";
          feedback.classList.remove("hidden");
          feedback.textContent = "¡Bien! ✨";
          feedback.style.color = "#5F6840";
        } else {
          stage.dataset.state = "";
          feedback.classList.add("hidden");
        }
      }

      function resetAll() {
        stage.innerHTML = "";
        stage.dataset.state = "";
        feedback.classList.add("hidden");
        bank.querySelectorAll<HTMLElement>(".sb-tile").forEach((t) => {
          t.dataset.used = "";
        });
      }

      bank.addEventListener("click", (e) => {
        const tile = (e.target as HTMLElement).closest<HTMLElement>(".sb-tile");
        if (!tile || tile.dataset.used === "1") return;
        const span = document.createElement("span");
        span.className = "sb-placed";
        span.dataset.token = tile.dataset.token!;
        span.dataset.bankRef = tile.dataset.origIndex!;
        span.textContent = tile.dataset.token!;
        stage.appendChild(span);
        tile.dataset.used = "1";
        check();
      });

      stage.addEventListener("click", (e) => {
        const span = (e.target as HTMLElement).closest<HTMLElement>(".sb-placed");
        if (!span || stage.dataset.state === "correct") return;
        const ref = span.dataset.bankRef!;
        const tile = bank.querySelector<HTMLElement>(`.sb-tile[data-orig-index="${ref}"]`);
        if (tile) tile.dataset.used = "";
        span.remove();
        check();
      });

      reset.addEventListener("click", resetAll);
    });
  }
  initSb();
  document.addEventListener("astro:page-load", initSb);
</script>
