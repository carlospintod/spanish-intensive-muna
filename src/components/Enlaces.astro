---
import SectionHeading from "./SectionHeading.astro";

interface Enlace { titulo: string; url: string; nota?: string }
interface Props {
  recomendados: Enlace[];
  directorio: Enlace[];
}
const { recomendados, directorio } = Astro.props;
---
<section class="section-card">
  <SectionHeading step={10} eyebrow="Directorio / enlaces" title="Si quieres más" />

  {recomendados.length > 0 && (
    <div class="mb-5">
      <p class="section-eyebrow">Recomendados</p>
      <ul class="mt-2 space-y-3">
        {recomendados.map((r) => (
          <li class="rounded-xl border border-terracotta-100 bg-terracotta-50/60 p-4">
            <a href={r.url} target="_blank" rel="noopener noreferrer" class="font-medium text-terracotta-700">
              {r.titulo} ↗
            </a>
            {r.nota && <p class="mt-1 text-sm text-ink-700">{r.nota}</p>}
          </li>
        ))}
      </ul>
    </div>
  )}

  {directorio.length > 0 && (
    <details class="rounded-xl bg-cream-100 px-4 py-3 open:pb-4">
      <summary class="cursor-pointer text-sm font-medium text-ink-700">Más cosas, por si te apetece curiosear</summary>
      <ul class="mt-3 space-y-2">
        {directorio.map((d) => (
          <li>
            <a href={d.url} target="_blank" rel="noopener noreferrer" class="text-sm text-terracotta-600">
              {d.titulo} ↗
            </a>
            {d.nota && <span class="ml-1 text-sm text-ink-500">— {d.nota}</span>}
          </li>
        ))}
      </ul>
    </details>
  )}
</section>
