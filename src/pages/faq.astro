---
import BaseLayout from "../layouts/BaseLayout.astro";

const faqs = [
  {
    q: "¿Cuánto tiempo necesito por unidad?",
    a: "Unos 15–25 minutos de lección, más la misión durante la semana. Una unidad ≈ una semana.",
  },
  {
    q: "¿Qué hago si una unidad es difícil?",
    a: "Repite el vídeo, haz la misión de casa en vez de la de la calle, y sigue. Puedes volver cuando quieras — esto no es un examen.",
  },
  {
    q: "¿Por qué español de España y no el de Duolingo?",
    a: "Este curso enseña el castellano — el que habla la abuela y el que oirás en el barrio. Algunas palabras cambian (coger, vale, vosotros); es a propósito.",
  },
  {
    q: "¿Tengo que escribir?",
    a: "No. Esto es sobre todo escuchar y hablar. La lectura es solo apoyo ligero.",
  },
  {
    q: "¿Y si no hago la misión?",
    a: "No pasa nada. Haz la versión fácil, o salta. Las misiones son donde está el aprendizaje de verdad, pero sin presión.",
  },
  {
    q: "¿Cómo uso el chat de práctica?",
    a: "Háblale en español a tu nivel; te corrige con cariño y solo cambia a inglés o swahili si tú se lo pides.",
  },
];
---
<BaseLayout title="FAQ" description="Preguntas frecuentes sobre el curso.">
  <h1 class="font-display text-4xl font-semibold text-ink-900 sm:text-5xl">Preguntas frecuentes</h1>

  <div class="mt-8 space-y-3">
    {faqs.map((f) => (
      <details class="rounded-2xl border border-cream-200 bg-white p-5 open:bg-cream-100">
        <summary class="cursor-pointer font-display text-lg font-semibold text-ink-900">{f.q}</summary>
        <p class="mt-3 leading-relaxed text-ink-700">{f.a}</p>
      </details>
    ))}
  </div>
</BaseLayout>
