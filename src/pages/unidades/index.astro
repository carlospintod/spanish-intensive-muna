---
import { getCollection } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { unitPlan } from "../../lib/unitPlan";

const units = (await getCollection("units")).sort((a, b) => a.data.unit - b.data.unit);
const bySlug = new Map(units.map((u) => [u.data.unit, u]));
---
<BaseLayout title="Unidades" description="Las 12 unidades del curso.">
  <h1 class="font-display text-4xl font-semibold text-ink-900 sm:text-5xl">Unidades</h1>
  <p class="mt-3 max-w-prose text-ink-700">
    Doce, en orden. Ve a tu ritmo — el orden está pensado, pero no es una cárcel.
  </p>

  <ol class="mt-8 space-y-3">
    {unitPlan.map((u) => {
      const match = bySlug.get(u.unit);
      return (
        <li>
          {match ? (
            <a
              href={`/unidades/${match.slug}`}
              class="flex flex-col gap-1 rounded-2xl border border-cream-200 bg-white p-5 no-underline transition hover:border-terracotta-100 hover:bg-terracotta-50/40 sm:flex-row sm:items-center sm:gap-5"
            >
              <span class="section-eyebrow shrink-0 sm:w-24">Unidad {u.unit}{u.abuelaCheckpoint && " ★"}</span>
              <div>
                <p class="font-display text-lg font-semibold text-ink-900">{u.title}</p>
                <p class="mt-0.5 text-sm text-ink-700">{u.goal}</p>
              </div>
            </a>
          ) : (
            <div class="flex flex-col gap-1 rounded-2xl border border-dashed border-cream-200 bg-cream-50 p-5 opacity-70 sm:flex-row sm:items-center sm:gap-5">
              <span class="section-eyebrow shrink-0 sm:w-24">Unidad {u.unit}{u.abuelaCheckpoint && " ★"}</span>
              <div>
                <p class="font-display text-lg font-semibold text-ink-700">{u.title}</p>
                <p class="mt-0.5 text-sm text-ink-500">{u.goal} <span class="ml-2 text-xs uppercase tracking-widest">próximamente</span></p>
              </div>
            </div>
          )}
        </li>
      );
    })}
  </ol>
</BaseLayout>
