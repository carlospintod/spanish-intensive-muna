---
import { getCollection } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";
import { unitPlan } from "../lib/unitPlan";

const units = (await getCollection("units")).sort((a, b) => a.data.unit - b.data.unit);
const firstUnit = units[0];
---
<BaseLayout title="Spanish for Muna" description="Un curso pequeño y cálido de español castellano, hecho para Muna.">
  <section class="rounded-3xl bg-gradient-to-br from-cream-100 via-cream-50 to-terracotta-50/60 p-7 shadow-warm ring-1 ring-cream-200 sm:p-12">
    <p class="section-eyebrow">Karibu · Bienvenida</p>
    <h1 class="mt-3 font-display text-4xl font-semibold text-ink-900 sm:text-6xl">
      Spanish for Muna.
    </h1>
    <p class="mt-4 max-w-prose text-lg leading-relaxed text-ink-700 sm:text-xl">
      Doce unidades pequeñas para llegar a una conversación tranquila con la abuela:
      del tiempo, de la comida, de la familia, de lo que cada una ha estado haciendo.
      Eso es la meta. Todo lo demás está al servicio de eso.
    </p>

    {firstUnit && (
      <div class="mt-7 flex flex-wrap gap-3">
        <a
          href={`/unidades/${firstUnit.slug}`}
          class="rounded-xl bg-terracotta-500 px-5 py-3 font-medium text-white no-underline shadow-warm hover:bg-terracotta-600"
        >
          Empezar por la Unidad 1 →
        </a>
        <a
          href="/unidades"
          class="rounded-xl border border-cream-200 bg-white px-5 py-3 font-medium text-ink-900 no-underline hover:border-terracotta-100"
        >
          Ver todas las unidades
        </a>
      </div>
    )}
  </section>

  <section class="mt-10">
    <h2 class="font-display text-2xl font-semibold text-ink-900 sm:text-3xl">El plan de las 12 unidades</h2>
    <p class="mt-2 max-w-prose text-ink-700">
      Cada unidad es una semana, más o menos. Las tres marcadas con ★ son las <em>llamadas con la abuela</em> —
      los hitos de verdad.
    </p>

    <ol class="mt-6 grid gap-3 sm:grid-cols-2">
      {unitPlan.map((u) => {
        const match = units.find((x) => x.data.unit === u.unit);
        const href = match ? `/unidades/${match.slug}` : null;
        return (
          <li>
            {href ? (
              <a
                href={href}
                class="block h-full rounded-2xl border border-cream-200 bg-white p-4 no-underline transition hover:border-terracotta-100 hover:bg-terracotta-50/40"
              >
                <div class="flex items-baseline justify-between gap-3">
                  <span class="section-eyebrow">Unidad {u.unit}</span>
                  {u.abuelaCheckpoint && <span class="pill">★ Abuela</span>}
                </div>
                <p class="mt-1 font-display text-lg font-semibold text-ink-900">{u.title}</p>
                <p class="mt-1 text-sm text-ink-700">{u.goal}</p>
              </a>
            ) : (
              <div class="block h-full rounded-2xl border border-dashed border-cream-200 bg-cream-50 p-4 opacity-70">
                <div class="flex items-baseline justify-between gap-3">
                  <span class="section-eyebrow">Unidad {u.unit}</span>
                  {u.abuelaCheckpoint && <span class="pill">★ Abuela</span>}
                </div>
                <p class="mt-1 font-display text-lg font-semibold text-ink-700">{u.title}</p>
                <p class="mt-1 text-sm text-ink-500">{u.goal}</p>
                <p class="mt-2 text-xs uppercase tracking-widest text-ink-500">próximamente</p>
              </div>
            )}
          </li>
        );
      })}
    </ol>
  </section>

  <section class="mt-12 rounded-3xl bg-cream-100 p-7 sm:p-10">
    <h2 class="font-display text-2xl font-semibold text-ink-900 sm:text-3xl">¿Cómo se usa?</h2>
    <ul class="mt-4 space-y-2 text-ink-900">
      <li>• Cada unidad: ~15–25 minutos de lección + una misión durante la semana.</li>
      <li>• Sin notas, sin rachas, sin culpa. Si una semana es regular, no pasa nada.</li>
      <li>• Está pensado para el móvil — la idea es poder hacerlo desde el sofá.</li>
    </ul>
    <p class="mt-5"><a href="/como-funciona">Ver la guía completa →</a></p>
  </section>
</BaseLayout>
